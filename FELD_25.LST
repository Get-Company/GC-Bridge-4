  Field: EndDat - Enddatum (Date) +
  Field: *AutoVKz - Vertrag automatisch verlängern (Boolean) +
  Field: FLaufZt - Folgelaufzeit (Byte) /
  Field: ZahlHBk - Hausbank (Integer) +
  Field: ZahlArt - Zahlungsart (Integer) +
  Field: MandatRef - Mandatsreferenz (Nummer) (UnicodeString) +
  Field: *MandatRefInfo - Mandatsreferenz (UnicodeString) +
  Field: *PNMitAbrAusKz - Pre-Notification wird mit jeder Abrechnung ausgegeben (Boolean) +
  Field: Abrech - Vertragsabrechnung (Byte) +
  Field: *AbrLaufZtKz - Laufzeitabrechnung ist fällig (Boolean) +
  Field: *AbrZaehlSKz - Zählerstandsabrechnung ist fällig (Boolean) +
  Field: *AbrVertragKz - Vertragsabrechnung ist fällig (Boolean) /
  Field: *KeinZuschlKz - Vertrag immer ohne Artikel-Zuschlag abrechnen (Boolean) /
