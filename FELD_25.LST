DataSet: Lohnarten - Lohnarten
  Field: ID - ID (AutoInc) +
  Field: LoANr - Lohnartennummer (UnicodeString) +
  Field: Bez - Bezeichnung (UnicodeString) +
  Field: LohnArt - Lohnart (Integer) +
  Field: NichtInGesBruttoKz - Keine Ausweisung der Lohnart im Gesamtbrutto (Boolean) +
  Field: Stat - Statistik (UnicodeString) +
  Field: MonatD - Monatsdurchschnitt (Integer) +
  Field: PLSt - pauschale Lohnsteuer (Integer) +
  Field: PLStNegMindBrtKz - Negative Bezüge mindern SV - und steuerpflichtiges Brutto Kennzeichen (Boolean) +
  Field: ANPStKz - Arbeitnehmer trägt anfallende pauschale Steuern (Boolean) +
  Field: ANPStLoANr - Lohnartennummer für Abzug der pauschalen Steuern (UnicodeString) +
  Field: Bezug - Nettobezug / -abzug (Integer) +
  Field: LohnTasche - Darstellung auf Lohntasche (Integer) +
  Field: ZusamKz - Zusammenfassen (Boolean) +
  Field: InGrundlohnKz - Berücksichtigung bei Ermittlung des Grundlohns (Boolean) +
  Field: SonstStKz - Sonstiger steuerpflichtiger Bezug (Boolean) +
  Field: KapAbfStKz - Kennzeichen für Kapitalauszahlung, Abfindung oder Sterbegeld (Boolean) +
  Field: EntschfStKz - Kennzeichen für Entschädigungen nach § 24 Nr. 1 EStG (Boolean) +
  Field: VmTStKz - Vergütung für mehrjährige Tätigkeit (Boolean) +
  Field: SonstSVKz - Sonstiger sozialversicherungspflichtiger Bezug (Boolean) +
  Field: EGAMitUmlKz - Berechnung der Umlage (Boolean) +
  Field: BuchSKz - Buchungssatz erzeugen (Boolean) +
  Field: NichtInBUebAZKz - Nicht in Buchungsübersicht unter "Andere Zahlung" ausweisen (Boolean) +
  Field: KtoNr - Kontonummer (UnicodeString) +
  Field: OhneKstKz - Ohne Kostenstellen-Vorbelegung Kennzeichen (Boolean) /
  Field: LStFrBet - steuerfreier Betrag (Double) +
  Field: LStFrSz - steuerfreier Satz (Double) +
  Field: SVFrBet - sozialversicherungsfreier Betrag (Double) +
  Field: SVFrSz - sozialversicherungsfreier Satz (Double) +
  Field: UVFrSz - unfallversicherungsfreier Satz (Double) /
  Field: Fak - Faktor (Double) +
  Field: StLohn - Stücklohn (Double) +
  Field: BerueckUml - Berücksichtigung für Umlage (Integer) +
  Field: BerueckUmlNetKz - Gesamtbetrag dieser Lohnart bezieht sich auf den Erstattungszeitraum (keine anteilige Berechnung) (Boolean) +
  Field: ErstattBAVKz - Erstattungsfähige AG-Zuwendungen zur betrieblichen Altersvorsorge (Boolean) +
  Field: BerueckMuSchuKz - Entgelt berücksichtigen (Boolean) +
  Field: NichtBerueckMuSchuKz - Entgelt nicht berücksichtigen (Boolean) +
  Field: EntgeltUmwBerueckKz - Abgaben aus Entgeltumwandlung berücksichtigen (Boolean) +
  Field: BGStdIgnor - Stundenanzahl dieser Lohnart ignorieren (Boolean) +
  Field: BGBetBerueck - Berücksichtigung obwohl SV-Frei (Boolean) +
  Field: BGBetNotBerueckKz - Keine Berücksichtigung wegen unwiderruflicher Freistellung  (Boolean) +
  Field: SFNZUschlag - Zuschlag (Integer) +
