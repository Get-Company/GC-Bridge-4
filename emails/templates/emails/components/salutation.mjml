{# emails/templates/emails/components/salutation.mjml #}
<mj-section background-color="#ffffff">
    <mj-column>
        <mj-text>
            <p>
                Hallo
                {if:anrede~Herr} Herr {/if}
                {if:anrede~Frau} Frau {/if}
                {subtag:name},
            </p>
        </mj-text>
    </mj-column>
    <mj-column>
        <mj-text align="right">
            <p>Ihre Kunden-Nr.: {subtag:adrnr}</p>
        </mj-text>
    </mj-column>
</mj-section>
