        <!-- Title -->
        
        <mj-section padding="20px" background-color="#ffffff">
    <mj-column>
        <mj-text>
            <h1 align="center" style="color: #ff9933; font-weight:400; line-height:40px">
                Classei Acrylglas-Boxen
            </h1>
            <h1 align="right" style="color: #8a8a8a; font-weight:400; line-height:36px">
                <small>
                    ..... elegant und funktionell
                </small>
            </h1>
        </mj-text>
    </mj-column>
</mj-section>
        

        <!-- Salutation -->
        <<mj-section>
    <mj-column>
        <mj-text>
            Hallo

            {if:anrede~Herr} Herr {/if}
            {if:anrede~Frau} Frau {/if}
            {subtag:name},
        </mj-text>
    </mj-column>
    <mj-column>
        <mj-text align="right">
            <p>
                Ihre Kunden-Nr.: {subtag:adrnr}
            </p>
        </mj-text>
    </mj-column>
</mj-section>

        <!-- Intro -->
        <mj-section>
            <mj-column width="400px">
                <mj-text>
                    <p>
                        Classei-Ordnung in eleganten Acrylglas-Boxen ist ein Blickfang für jeden Schreibtisch.
                        Funktionelle und zeitgemäße Ordnung gepaart mit edlem und zeitlosem Design. So macht das
                        Arbeiten mit dem Classei-System rund um den Schreibtisch noch mehr Spaß.
                    </p>
                </mj-text>
            </mj-column>
            <mj-column vertical-align="middle" width="150px">
                <mj-button
                        height="100%"
                        vertical-align="middle"
                        font-family="Roboto"
                        background-color="#ff9933"
                        color="white"
                        font-size="20px"
                        line-height="30px"
                >
                    15% Rabatt
                </mj-button>
            </mj-column>
        </mj-section>

        <mj-wrapper>
            <!-- Subheader Griff-Hängeleisten -->
            
            <mj-section>
    <mj-column>
        <mj-text align="center" line-height="40px">
            <h2 style="font-size: 30px; color: #ff9933">Acrylglas-Boxen</h2>
        </mj-text>
    </mj-column>
</mj-section>
            
        </mj-wrapper>

        <!-- Products -->
        
        <mj-wrapper>
    <!-- Product Head -->
    <mj-section background-color="#ffffff">
        <mj-column>
            <mj-text>
